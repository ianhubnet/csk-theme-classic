root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = tab
insert_final_newline = true
trim_trailing_whitespace = true

[{*.sql,*.yml,*.yaml,*.cff}]
indent_size = 2
indent_style = space
insert_final_newline = true

[*.md]
indent_size = 2
indent_style = space

[{*.txt,*.dist}]
end_of_line = crlf
